{
  "files.eol": "\n",
  "editor.formatOnSave": false,
  "python.REPL.enableREPLSmartSend": false,
  "eslint.enable": true,
  "eslint.validate": [
    "javascript",
    "typescript",
    "html",
    "css",
    "json",
    "markdown"
  ],
  "search.exclude": {
    "**/__pycache__": true,
    "**/node_modules": true,
    "**/venv": true,
    "**/*.mjs": true,
    "**/*.map": true
  },
  "githubPullRequests.ignoredPullRequestBranches": [
    "master"
  ]
}
